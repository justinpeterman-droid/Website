---
import type { Service } from '../content/site';

interface Props extends Service {
  index: number;
}

const { title, description, image, imageAlt, index } = Astro.props;

const staggerDelay = index * 100;
---

<div class="reveal h-full" data-reveal-delay={staggerDelay}>
  <article class="premium-card group flex h-full flex-col overflow-hidden rounded-2xl border border-border-light bg-surface shadow-card">
    <div class="relative aspect-[4/3] overflow-hidden bg-background">
      <img
        src={image}
        alt={imageAlt}
        class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
        loading="lazy"
        width="900"
        height="675"
      />
      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-t from-dark/25 via-transparent to-transparent"
        aria-hidden="true"
      />
    </div>

    <div class="flex flex-1 flex-col p-6 md:p-7">
      <p class="mb-2 text-xs font-semibold uppercase tracking-[0.16em] text-accent-sage">Service</p>
      <h3 class="text-lg font-semibold leading-snug tracking-tight text-heading md:text-xl">
        {title}
      </h3>
      <p class="mt-3 flex-1 text-sm leading-relaxed text-muted">{description}</p>
    </div>
  </article>
</div>
