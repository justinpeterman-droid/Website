---
import Button from './Button.astro';
import { site } from '../content/site';

const { cta, contact } = site;
---

<section class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div class="reveal relative overflow-hidden rounded-2xl border border-border-light bg-dark px-8 py-14 text-center text-white shadow-card-dark md:px-16 md:py-20" data-reveal-delay="0">
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(107,143,113,0.2),transparent_50%),radial-gradient(circle_at_80%_80%,rgba(124,107,158,0.18),transparent_55%)]"
        aria-hidden="true"
      />

      <div class="relative">
        <h2 class="text-3xl font-bold tracking-tight md:text-5xl">
          {cta.headline}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-white/75 md:text-lg">
          {cta.body}
        </p>
        <div class="mt-8">
          <Button href={contact.bookingUrl} external class="!bg-white !text-dark hover:!bg-white/90">
            {cta.cta}
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
