---
import { site } from '../content/site';

const { cta, contact } = site;
---

<section class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div
      class="reveal-3d relative overflow-hidden rounded-3xl px-8 py-14 text-center text-white shadow-card-dark md:px-16 md:py-20"
      data-reveal-delay="0"
      data-tilt
      data-tilt-max="5"
    >
      <div class="absolute inset-0 bg-dark" aria-hidden="true"></div>
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(134,36,255,0.45),transparent_45%),radial-gradient(circle_at_80%_80%,rgba(131,202,22,0.35),transparent_50%),radial-gradient(circle_at_50%_50%,rgba(34,210,237,0.2),transparent_60%)]"
        aria-hidden="true"
      />
      <div class="mesh-blob mesh-blob-1 !opacity-30" aria-hidden="true"></div>

      <div class="relative">
        <h2 class="text-3xl font-bold tracking-tight md:text-5xl">
          <span class="text-gradient-warm">{cta.headline}</span>
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-relaxed text-white/80 md:text-lg">
          {cta.body}
        </p>
        <a
          href={contact.bookingUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-magnetic
          class="btn-glow relative mt-8 inline-flex items-center justify-center rounded-full px-8 py-3.5 text-sm font-semibold text-dark"
        >
          {cta.cta}
        </a>
      </div>
    </div>
  </div>
</section>
