---
import SectionLabel from './SectionLabel.astro';
import { site } from '../content/site';

const { mission } = site;
---

<section id="approach" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div class="grid gap-12 lg:grid-cols-2 lg:items-start">
      <div class="reveal">
        <SectionLabel text={mission.label} />
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-heading md:text-5xl">
          {mission.headline}
        </h2>
        {
          mission.body.map((paragraph) => (
            <p class="mt-4 text-base leading-relaxed text-muted md:text-lg">{paragraph}</p>
          ))
        }
      </div>

      <div class="reveal premium-card rounded-3xl bg-dark p-8 text-white shadow-card-dark md:p-10" data-reveal-delay="200">
        <h3 class="text-2xl font-semibold tracking-tight md:text-3xl">
          {mission.secondaryHeadline}
        </h3>
        {
          mission.secondaryBody.map((paragraph) => (
            <p class="mt-4 text-sm leading-relaxed text-white/75 md:text-base">{paragraph}</p>
          ))
        }
      </div>
    </div>
  </div>
</section>
