---
import Button from './Button.astro';
import { site } from '../content/site';

const { hero, contact, brand, social } = site;
const { image } = hero;
---

<section class="relative min-h-[min(100svh,920px)] overflow-hidden pb-20 pt-28 md:pb-28 md:pt-32">
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style={`background-image: url('${image.src}')`}
    role="img"
    aria-label={image.alt}
  />
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-r from-dark/88 via-dark/62 to-dark/40"
    aria-hidden="true"
  />
  <div
    class="pointer-events-none absolute inset-0 bg-gradient-to-t from-dark/55 via-transparent to-dark/25"
    aria-hidden="true"
  />

  <div class="relative mx-auto flex min-h-[calc(min(100svh,920px)-12rem)] max-w-6xl items-center px-5 md:px-8">
    <div class="reveal max-w-2xl" data-reveal-delay="0">
      <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.18em] text-white/90 backdrop-blur-sm">
        <span class="h-1.5 w-1.5 rounded-full bg-accent-sage-light"></span>
        {hero.eyebrow}
      </p>
      <h1 class="text-4xl font-bold leading-[1.1] tracking-tight text-white md:text-5xl lg:text-6xl">
        {hero.headline}
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-white/85 md:text-xl">
        {hero.subtext}
      </p>

      <div class="mt-10 flex flex-col gap-5 sm:flex-row sm:items-center">
        <Button href={contact.bookingUrl} external>
          {hero.cta}
        </Button>
        <div class="flex items-center gap-4">
          <a
            href={social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-white/75 transition-colors hover:text-white"
          >
            @Hometownserenity
          </a>
          <span class="text-white/35" aria-hidden="true">·</span>
          <p class="text-sm text-white/65">
            {brand.owner}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
