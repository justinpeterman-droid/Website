---
import SectionLabel from './SectionLabel.astro';
import { site } from '../content/site';

const { about } = site;
---

<section id="about" class="py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div class="reveal lg:sticky lg:top-32" data-reveal-delay="0">
        <div class="overflow-hidden rounded-2xl border border-border-light bg-surface shadow-card">
          <img
            src={about.headshot}
            alt={about.headshotAlt}
            class="aspect-[4/5] w-full object-cover"
            loading="lazy"
            width="900"
            height="1125"
          />
        </div>
        <p class="mt-4 text-center text-sm text-muted-light lg:text-left">
          Ashley Romero · CMH, CAHA
        </p>
      </div>

      <div class="reveal" data-reveal-delay="120">
        <SectionLabel text={about.label} />
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-heading md:text-5xl">
          {about.headline}
        </h2>
        {
          about.bio.map((paragraph) => (
            <p class="mt-4 text-base leading-relaxed text-muted md:text-lg">{paragraph}</p>
          ))
        }

        <blockquote class="premium-card mt-10 rounded-2xl border border-border-light bg-surface p-8 shadow-card md:p-10">
          <svg class="mb-4 h-7 w-7 text-accent-sage" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
            <path d="M10 8c-3.3 0-6 2.7-6 6v8h8v-8H8c0-1.1.9-2 2-2V8zm14 0c-3.3 0-6 2.7-6 6v8h8v-8h-4c0-1.1.9-2 2-2V8z" />
          </svg>
          <p class="text-lg leading-relaxed text-heading md:text-xl">{about.quote}</p>
        </blockquote>

        <p class="mt-8 text-lg font-medium text-heading">{about.closing}</p>
      </div>
    </div>
  </div>
</section>
