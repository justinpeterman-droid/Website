---
const imageUrl =
  'https://images.unsplash.com/photo-1506126613408-eca07ce68773?auto=format&fit=crop&w=2400&q=80';
---

<section class="py-8 md:py-12" aria-label="Wellness imagery">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div class="reveal overflow-hidden rounded-3xl shadow-card">
      <img
        src={imageUrl}
        alt="Calm natural landscape with soft morning light"
        class="aspect-[21/9] w-full object-cover"
        loading="lazy"
        width="2400"
        height="1029"
      />
    </div>
  </div>
</section>
