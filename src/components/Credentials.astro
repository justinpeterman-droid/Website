---
import { site } from '../content/site';

const { brand } = site;
---

<section class="border-y border-border-light bg-white/60 py-8" aria-label="Credentials">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-3 px-5 md:gap-4 md:px-8">
    {
      brand.credentials.map((credential, index) => (
        <>
          <span class="rounded-full border border-border bg-background px-4 py-2 text-sm font-semibold text-heading shadow-card">
            {credential}
          </span>
          {index < brand.credentials.length - 1 && (
            <span class="hidden text-muted-light md:inline" aria-hidden="true">
              ·
            </span>
          )}
        </>
      ))
    }
  </div>
</section>
