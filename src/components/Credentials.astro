---
import { site } from '../content/site';

const { brand } = site;
---

<section class="border-y border-border-light py-8" aria-label="Credentials">
  <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-3 px-5 md:gap-4 md:px-8">
    {
      brand.credentials.map((credential, index) => (
        <span
          class="reveal rounded-full border border-border-light bg-surface px-5 py-2.5 text-sm font-medium text-heading shadow-card"
          data-reveal-delay={index * 80}
        >
          {credential}
        </span>
      ))
    }
  </div>
</section>
