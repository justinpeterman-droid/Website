---
import { site } from '../content/site';

const { brand } = site;

const badgeColors = [
  'from-accent-purple/20 to-accent-cyan/15 text-accent-purple ring-accent-purple/25',
  'from-accent-lime/20 to-accent-cyan/15 text-heading ring-accent-lime/30',
  'from-accent-pink/20 to-accent-coral/15 text-heading ring-accent-pink/25',
];
---

<section class="relative overflow-hidden border-y border-border-light py-8" aria-label="Credentials">
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-r from-accent-purple/5 via-accent-cyan/5 to-accent-lime/5" aria-hidden="true"></div>
  <div class="relative mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-3 px-5 md:gap-4 md:px-8">
    {
      brand.credentials.map((credential, index) => (
        <span
          class={`reveal rounded-full bg-gradient-to-r px-5 py-2.5 text-sm font-semibold shadow-card ring-1 backdrop-blur-sm ${badgeColors[index % badgeColors.length]}`}
          data-reveal-delay={index * 100}
        >
          {credential}
        </span>
      ))
    }
  </div>
</section>
