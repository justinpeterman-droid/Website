---
import Button from './Button.astro';
import { site } from '../content/site';

const { brand, nav, contact, hero } = site;
---

<header
  id="top"
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-all duration-300"
  data-nav
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4 md:px-8"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="text-sm font-semibold tracking-tight text-heading transition-colors hover:text-accent-sage md:text-base"
    >
      {brand.name}
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {
        nav.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-muted transition-colors hover:text-heading"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <Button href={contact.bookingUrl} external class="!px-4 !py-2.5 md:!px-5">
      {hero.cta}
    </Button>
  </nav>
</header>

<script>
  const header = document.querySelector('[data-nav]');
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 24) {
      header.classList.add('border-border-light', 'bg-surface/85', 'backdrop-blur-xl', 'shadow-card');
    } else {
      header.classList.remove('border-border-light', 'bg-surface/85', 'backdrop-blur-xl', 'shadow-card');
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
