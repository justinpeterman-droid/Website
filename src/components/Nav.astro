---
import { site } from '../content/site';

const { brand, nav, contact, hero } = site;
---

<header
  id="top"
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-all duration-300"
  data-nav
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-4 md:px-8"
    aria-label="Main navigation"
  >
    <a
      href="#top"
      class="text-sm font-semibold tracking-tight transition-colors hover:text-accent-purple md:text-base"
    >
      <span class="text-gradient-pop">{brand.name}</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {
        nav.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-muted transition-colors hover:text-accent-purple"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <a
      href={contact.bookingUrl}
      target="_blank"
      rel="noopener noreferrer"
      data-magnetic
      class="btn-glow relative inline-flex items-center justify-center rounded-full px-4 py-2.5 text-sm font-semibold text-dark md:px-5"
    >
      {hero.cta}
    </a>
  </nav>
</header>

<script>
  const header = document.querySelector('[data-nav]');
  const onScroll = () => {
    if (!header) return;
    if (window.scrollY > 24) {
      header.classList.add(
        'border-accent-purple/10',
        'bg-white/75',
        'backdrop-blur-xl',
        'shadow-glow-purple'
      );
    } else {
      header.classList.remove(
        'border-accent-purple/10',
        'bg-white/75',
        'backdrop-blur-xl',
        'shadow-glow-purple'
      );
    }
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
