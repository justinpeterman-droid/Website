---
import Button from './Button.astro';
import PreviewWindow from './PreviewWindow.astro';
import { site } from '../content/site';

const { brand, contact, social, nav, hero, footer } = site;
const phoneHref = `tel:${contact.phone.replace(/[^\d+]/g, '')}`;
---

<footer id="contact" class="border-t border-border-light py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-5 md:px-8">
    <div class="mb-4 text-center md:mb-6">
      <h2 class="text-2xl font-bold tracking-tight text-heading md:text-3xl">
        Connect with {brand.name}
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-muted">
        Explore each destination below — every link opens what it represents in a live preview.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
      {
        footer.linkCards.map((card) => (
          <a
            href={card.href}
            target={card.external ? '_blank' : undefined}
            rel={card.external ? 'noopener noreferrer' : undefined}
            class="premium-card group flex flex-col rounded-2xl border border-border-light bg-surface p-4 shadow-card"
          >
            {card.preview && (
              <PreviewWindow
                url={card.preview.url}
                image={card.preview.image}
                alt={card.preview.alt}
                label={card.preview.badge}
              />
            )}
            <div class="mt-4">
              <p class="text-sm font-semibold text-heading transition-colors group-hover:text-accent-sage">
                {card.label}
              </p>
              {card.description && (
                <p class="mt-1 text-xs text-muted-light">{card.description}</p>
              )}
            </div>
          </a>
        ))
      }
    </div>

    <div class="mt-16 text-center md:mt-20">
      <div class="reveal inline-flex items-center gap-2 rounded-full border border-border-light bg-surface px-4 py-2 text-sm text-muted shadow-card" data-reveal-delay="0">
        <span class="h-2 w-2 rounded-full bg-accent-sage" aria-hidden="true"></span>
        {footer.status}
      </div>

      <a
        href={`mailto:${contact.email}`}
        class="mt-8 block break-all text-3xl font-bold tracking-tight text-heading transition-colors hover:text-accent-sage sm:text-4xl md:text-5xl"
      >
        {contact.email}
      </a>

      <a
        href={phoneHref}
        class="mt-3 inline-block text-lg font-medium text-muted transition-colors hover:text-heading"
      >
        {contact.phone}
      </a>

      <p class="mx-auto mt-6 max-w-xl text-base text-muted md:text-lg">
        {footer.tagline}
      </p>

      <p class="mt-3 text-sm text-muted-light">
        {brand.owner} · {brand.credentials.join(' · ')}
      </p>
    </div>

    <div class="mt-14 flex justify-center md:mt-16">
      <nav
        class="inline-flex flex-wrap items-center justify-center gap-1 rounded-full border border-border-light bg-surface/90 p-1.5 shadow-card backdrop-blur-md"
        aria-label="Footer navigation"
      >
        {
          nav.map((link) => (
            <a
              href={link.href}
              class="rounded-full px-4 py-2 text-sm font-medium text-muted transition-colors hover:bg-background hover:text-heading"
            >
              {link.label}
            </a>
          ))
        }
        <Button href={contact.bookingUrl} external class="!px-5 !py-2">
          {hero.cta}
        </Button>
      </nav>
    </div>

    <div class="mt-12 flex flex-col items-center gap-6 border-t border-border-light pt-8 md:flex-row md:justify-between">
      <div class="flex items-center gap-4">
        <a
          href={social.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-10 w-10 items-center justify-center rounded-full border border-border-light bg-surface text-muted transition-colors hover:border-accent-sage hover:text-heading"
          aria-label="Instagram @Hometownserenity"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
          </svg>
        </a>
        <a
          href={social.facebook}
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-10 w-10 items-center justify-center rounded-full border border-border-light bg-surface text-muted transition-colors hover:border-accent-sage hover:text-heading"
          aria-label="Facebook Ashley Romero CMH"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
          </svg>
        </a>
        <a
          href={phoneHref}
          class="flex h-10 w-10 items-center justify-center rounded-full border border-border-light bg-surface text-muted transition-colors hover:border-accent-sage hover:text-heading"
          aria-label={`Call ${contact.phone}`}
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.72 1.012a12.042 12.042 0 01-5.516-5.517l1.013-.72c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </a>
      </div>

      <div class="flex flex-wrap justify-center gap-4 text-sm text-muted-light">
        <a href={contact.supportFormUrl} target="_blank" rel="noopener noreferrer" class="hover:text-heading">
          Privacy Policy
        </a>
        <a href={contact.supportFormUrl} target="_blank" rel="noopener noreferrer" class="hover:text-heading">
          Terms &amp; Support
        </a>
      </div>
    </div>

    <p class="mt-6 text-center text-sm text-muted-light">{footer.copyright}</p>
    <p class="mt-2 text-center text-xs text-muted-light">
      {footer.education.join(' · ')}
    </p>
    <p class="mt-2 text-center text-xs text-muted-light">
      {footer.domains.join(' · ')}
    </p>
  </div>
</footer>
