---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Credentials from '../components/Credentials.astro';
import Services from '../components/Services.astro';
import Archive from '../components/Archive.astro';
import Mission from '../components/Mission.astro';
import Reflection from '../components/Reflection.astro';
import About from '../components/About.astro';
import CTABand from '../components/CTABand.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import MotionEffects from '../components/MotionEffects.astro';
import { site } from '../content/site';
---

<BaseLayout
  title={`${site.brand.name} | ${site.brand.owner}`}
  description={site.hero.subtext}
>
  <Nav />
  <main>
    <Hero />
    <Credentials />
    <Services />
    <Archive />
    <Mission />
    <Reflection />
    <About />
    <CTABand />
    <FAQ />
  </main>
  <Footer />
  <ScrollReveal />
  <MotionEffects />
</BaseLayout>
