---
import SiteLayout from '../layouts/SiteLayout.astro';
import Hero from '../components/Hero.astro';
import Credentials from '../components/Credentials.astro';
import Services from '../components/Services.astro';
import Mission from '../components/Mission.astro';
import Reflection from '../components/Reflection.astro';
import About from '../components/About.astro';
import CTABand from '../components/CTABand.astro';
import FAQ from '../components/FAQ.astro';
import { site } from '../content/site';
---

<SiteLayout
  title={`${site.brand.name} | ${site.brand.owner}`}
  description={site.hero.subtext}
  transparentNav
>
  <Hero />
  <Credentials />
  <Services />
  <Mission />
  <Reflection />
  <About />
  <CTABand />
  <FAQ />
</SiteLayout>
